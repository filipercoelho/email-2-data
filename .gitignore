.DS_Store
.AppleDouble
.LSOverride

# Env
.env
.env.*

# Python
__pycache__/
*.py[cod]
.venv/
.pytest_cache/

# Node
node_modules/

# Logs
*.log

# Secrets & local data — never commit
config/settings.json
labels/*.csv
corpus/*.eml
# out/ holds personal data (subjects, addresses, bodies, contact DB) — ignore all but the keep file
out/*
!out/.gitkeep

# Python build artifacts
*.egg-info/
