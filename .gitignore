.DS_Store
.AppleDouble
.LSOverride

# Env — never commit real .env files; the template IS committed so others know what to fill in
.env
.env.*
!.env.example

# Credentials & keys — never commit
.secret
*.pem
*.key
*-key.json
config/sa-key.json
service-account*.json
credentials*.json
sa.json
gcloud-*.json

# Python
__pycache__/
*.py[cod]
.venv/
.pytest_cache/

# Node
node_modules/

# Logs
*.log

# Local data — never commit (real inbox content, contact DBs, watermarks)
config/settings.json
labels/*.csv
corpus/*.eml
*.db
*.sqlite
*.sqlite3
# out/ holds personal data (subjects, addresses, bodies, contact DB) — ignore all but the keep file
out/*
!out/.gitkeep

# Python build artifacts
*.egg-info/
