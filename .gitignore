.DS_Store
.AppleDouble
.LSOverride

# Env — never commit real .env files; the template IS committed so others know what to fill in
.env
.env.*
!.env.example

# Credentials & keys — never commit
.secret
*.pem
*.key
*-key.json
config/sa-key.json
service-account*.json
credentials*.json
sa.json
gcloud-*.json

# Python
__pycache__/
*.py[cod]
.venv/
.pytest_cache/

# Node
node_modules/

# Logs
*.log

# Local data — never commit (real inbox content, contact DBs, watermarks)
config/settings.json
labels/*.csv
corpus/*.eml
*.db
*.sqlite
*.sqlite3
# SQLite WAL sidecars (workspace.db runs in WAL mode; the intake worker is a 2nd writer — ADR-021).
# `*.db` is matched literally, so the -wal/-shm siblings need their own globs. (out/* already covers the
# real out/workspace.db-* pair; these guard a db opened elsewhere, e.g. a stray root-level copy.)
*.db-wal
*.db-shm
# Conversational-intake media (ADR-020): PRECIOUS sole-copy photos/audio — never committed; it lives
# in the backup set instead (see docs/05-reference/data-stores.md). The intake worker writes here.
captures/
# out/ holds personal data (subjects, addresses, bodies, contact DB) + the regenerable intake offset
# cursor (out/intake_offset.json) — ignore all but the keep file
out/*
!out/.gitkeep

# Python build artifacts
*.egg-info/
