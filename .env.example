# email-2-data secrets — copy to `.env` and fill in. NEVER commit `.env` (it is gitignored).
# Loaded automatically by the CLI/webapp (config.load_dotenv). A real exported env var overrides these.
# No more `export VAR=...` — put values here instead. Values are read LITERALLY (the app's own loader,
# not a shell): no quoting or escaping needed, and characters like `$` are kept as-is.

# Read-only IMAP password for the account whose `password_env` is EMAIL2DATA_ORCAMENTOS_PASSWORD
# (see config/settings.json -> imap.accounts[].password_env). Provided per session; never stored in settings.json.
EMAIL2DATA_ORCAMENTOS_PASSWORD=
# Read-only IMAP password for luis.coelho@lindoservico.pt
EMAIL2DATA_LUIS_PASSWORD=

# LLM provider auth — only ONE is needed, matching settings.json -> llm.provider:
#
#   provider = "vertex_gemini" (this project's default):
#     • Local runs  -> `gcloud auth application-default login` once; leave the var below blank.
#                      (Or set it to the ABSOLUTE host path of a service-account JSON.)
#     • Docker       -> docker-compose mounts your gcloud login into the container by default, so you
#                      usually leave this blank. For a server with no login, put a service-account
#                      JSON at config/sa-key.json and uncomment GOOGLE_APPLICATION_CREDENTIALS in
#                      docker-compose.yml (it resolves to /app/config/sa-key.json in the container).
GOOGLE_APPLICATION_CREDENTIALS=
#
#   provider = "anthropic"      -> set the API key instead (and leave the line above blank).
ANTHROPIC_API_KEY=
